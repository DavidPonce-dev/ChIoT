{
  "name": "chiot",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "backend",
    "frontend",
    "app",
    "firmware"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:app": "npm run start --workspace=app",
    "build": "npm run build --workspace=backend",
    "build:frontend": "npm run build --workspace=frontend",
    "build:firmware": "powershell -Command \"cd firmware; & 'C:\\esp\\v6.0\\esp-idf\\export.ps1'; idf.py build\"",
    "build:all": "npm run build --workspace=backend && npm run build:frontend && npm run build:firmware",
    "start": "npm run start --workspace=backend",
    "start:frontend": "npm run start --workspace=frontend",
    "lint": "npm run lint --workspace=backend && npm run lint --workspace=frontend",
    "typecheck": "npm run typecheck --workspace=backend && npm run typecheck --workspace=frontend",
    "test": "npm run test --workspace=backend",
    "up": "docker compose --profile dev up -d --build",
    "down": "docker compose --profile dev down",
    "logs": "docker compose logs -f",
    "logs:backend": "docker compose logs -f backend",
    "logs:frontend": "docker compose logs -f frontend",
    "reset:frontend": "docker stop ChIoT-frontend && docker rm ChIoT-frontend && docker compose up -d frontend"
  }
}
